{
  "name": "giles",
  "description": "A plugin for agile agentic coding that takes it too far",
  "version": "0.7.0",
  "author": {
    "name": "Jon Rubin",
    "email": "jb.rubin@gmail.com",
    "url": "https://github.com/jbrjake"
  },
  "repository": "https://github.com/jbrjake/giles",
  "license": "MIT",
  "keywords": ["agile", "sprint", "scrum", "burndown", "PR"],
  "skills": "./skills/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/review_gate.py\""
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/commit_gate.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/commit_gate.py\" --post"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/verify_agent_output.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/session_context.py\""
          }
        ]
      }
    ]
  }
}
