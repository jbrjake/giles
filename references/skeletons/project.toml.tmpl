# Sprint Process Configuration
# Generated by sprint-init. Review and customize.

[project]
name = "TODO-project-name"
repo = "TODO-owner/repo"       # GitHub owner/repo
language = "TODO-language"     # rust | python | node | go | java
base_branch = "main"          # branch that PRs target and CI watches

[paths]
team_dir = "sprint-config/team"
backlog_dir = "sprint-config/backlog"
rules_file = "sprint-config/rules.md"
dev_guide = "sprint-config/development.md"
sprints_dir = "docs/dev-team/sprints"    # Created by sprint-setup
# Optional:
# cheatsheet = "CHEATSHEET.md"
# architecture = "ARCHITECTURE.md"

[ci]
check_commands = [
    # TODO: Add your project's check commands
    # Examples:
    #   "cargo fmt --check",
    #   "cargo clippy -- -D warnings",
    #   "cargo test",
    #   "ruff check .",
    #   "pytest",
    #   "npm run lint",
    #   "npm test",
]
build_command = "TODO-build-command"   # e.g., "cargo build --release"
# binary_path = "target/release/myapp"  # Optional
# size_limit_mb = 50                     # Optional

[conventions]
branch_pattern = "sprint-{N}/US-{ID}-{slug}"
commit_style = "conventional"    # conventional | freeform
merge_strategy = "squash"        # squash | merge | rebase

[labels]
# Additional project-specific label categories
# The skill always creates: kanban:*, priority:*, type:*
# Persona and saga labels are auto-generated from team/ and backlog/
# custom = [
#     { prefix = "component", values = ["frontend", "backend", "api"] },
# ]

[release]
version_scheme = "semver"        # semver | calver
# milestones = [
#     { name = "R1", version = "0.1.0" },
# ]
